#! /usr/bin/vvp
:ivl_version "11.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x58f701b46bc0 .scope module, "basic_tb" "basic_tb" 2 3;
 .timescale -9 -12;
v0x58f701b580f0_0 .var "x", 0 0;
v0x58f701b581c0_0 .var "y", 0 0;
v0x58f701b58290_0 .net "z", 0 0, L_0x58f701b58390;  1 drivers
S_0x58f701b46d50 .scope module, "uut" "andGate" 2 11, 3 1 0, S_0x58f701b46bc0;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "x";
    .port_info 1 /INPUT 1 "y";
    .port_info 2 /OUTPUT 1 "z";
L_0x58f701b58390 .functor AND 1, v0x58f701b580f0_0, v0x58f701b581c0_0, C4<1>, C4<1>;
v0x58f701b0fba0_0 .net "x", 0 0, v0x58f701b580f0_0;  1 drivers
v0x58f701b57f10_0 .net "y", 0 0, v0x58f701b581c0_0;  1 drivers
v0x58f701b57fd0_0 .net "z", 0 0, L_0x58f701b58390;  alias, 1 drivers
    .scope S_0x58f701b46bc0;
T_0 ;
    %vpi_call 2 20 "$dumpfile", "andGate_waves.vcd" {0 0 0};
    %vpi_call 2 21 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x58f701b46bc0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x58f701b580f0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x58f701b581c0_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x58f701b580f0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x58f701b581c0_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x58f701b580f0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x58f701b581c0_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x58f701b580f0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x58f701b581c0_0, 0, 1;
    %delay 10000, 0;
    %vpi_call 2 29 "$finish" {0 0 0};
    %end;
    .thread T_0;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "basic_tb.v";
    "and.v";
