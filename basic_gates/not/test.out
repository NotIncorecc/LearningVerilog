#! /usr/bin/vvp
:ivl_version "11.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5f16788f6d90 .scope module, "notGate_tb" "notGate_tb" 2 2;
 .timescale 0 0;
v0x5f167893f3b0_0 .var "a", 0 0;
v0x5f167893f450_0 .net "c", 0 0, L_0x5f167893f520;  1 drivers
S_0x5f16788f6f20 .scope module, "notGate_inst" "notGate" 2 10, 3 1 0, S_0x5f16788f6d90;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /OUTPUT 1 "c";
L_0x5f167893f520 .functor NOT 1, v0x5f167893f3b0_0, C4<0>, C4<0>, C4<0>;
v0x5f16788f8ba0_0 .net "a", 0 0, v0x5f167893f3b0_0;  1 drivers
v0x5f167893f290_0 .net "c", 0 0, L_0x5f167893f520;  alias, 1 drivers
    .scope S_0x5f16788f6d90;
T_0 ;
    %vpi_call 2 18 "$dumpfile", "notGate_waves.vcd" {0 0 0};
    %vpi_call 2 19 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5f16788f6d90 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5f167893f3b0_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5f167893f3b0_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 25 "$finish" {0 0 0};
    %end;
    .thread T_0;
