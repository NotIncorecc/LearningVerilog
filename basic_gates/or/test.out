    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x59da9602f160_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x59da9602f090_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x59da9602f160_0, 0, 1;
    %delay 10, 0;
