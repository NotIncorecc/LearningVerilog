    .scope S_0x59da9601dbf0;
T_0 ;
    %vpi_call 2 19 "$dumpfile", "orGate_waves.vcd" {0 0 0};
    %vpi_call 2 20 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x59da9601dbf0 {0 0 0};
    %pushi/vec4 0, 0, 1;
