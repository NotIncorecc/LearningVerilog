    %store/vec4 v0x630734056f00_0, 0, 4;
    %delay 10000, 0;
    %vpi_call 2 30 "$display", "t=%0t | rst=%b load=%b d=%b | q=%b (reset)", $time, v0x6307340571a0_0, v0x630734056fd0_0, v0x630734056f00_0, v0x6307340570d0_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
