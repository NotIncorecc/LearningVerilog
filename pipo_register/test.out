    .thread T_0;
    .scope S_0x630734001490;
T_1 ;
    %delay 5000, 0;
    %load/vec4 v0x630734056e40_0;
    %inv;
    %store/vec4 v0x630734056e40_0, 0, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_0x630734001490;
