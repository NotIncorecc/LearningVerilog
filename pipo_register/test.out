    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x6307340571a0_0, 0, 1;
    %pushi/vec4 12, 0, 4;
    %store/vec4 v0x630734056f00_0, 0, 4;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x630734056fd0_0, 0, 1;
