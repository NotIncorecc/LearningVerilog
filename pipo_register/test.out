v0x630734056bb0_0 .var "q", 3 0;
v0x630734056c90_0 .net "rst", 0 0, v0x6307340571a0_0;  1 drivers
E_0x630734001d90 .event posedge, v0x630734001820_0;
    .scope S_0x630734001620;
T_0 ;
    %wait E_0x630734001d90;
    %load/vec4 v0x630734056c90_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x630734056bb0_0, 0;
    %jmp T_0.1;
